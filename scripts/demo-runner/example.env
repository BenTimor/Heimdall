# Fresh Ubuntu x64 VPS runner bootstrap example.
# Source this file, replace the placeholders, then run:
#   sudo -E bash ./scripts/demo-runner/bootstrap-ubuntu-runner.sh

# GitHub runner target.
# Repository example: https://github.com/owner/repo
# Organization example: https://github.com/my-org
export GITHUB_RUNNER_URL="https://github.com/owner/repo"

# Choose one:
# 1. short-lived registration token copied from GitHub runner setup UI
export GITHUB_RUNNER_TOKEN=""

# 2. or a PAT / app token that can create registration tokens
# Repository scope: repository Administration (write) or classic repo scope
# Organization scope: admin:org or equivalent app permission
export GITHUB_PAT=""

# Custom runner settings
export GITHUB_RUNNER_NAME="heimdall-demo-01"
export GITHUB_RUNNER_LABELS="heimdall-demo"
export GITHUB_RUNNER_GROUP=""
export GITHUB_RUNNER_WORKDIR="_work"

# Cleanup hooks wipe the runner work directory and OpenCode state before and
# after each job. Keep this on unless you are debugging locally.
export GITHUB_RUNNER_ENABLE_HOOKS="true"

# Optional pin to a specific repo ref when building the local agent.
export HEIMDALL_GIT_URL="https://github.com/BenTimor/Heimdall.git"
export HEIMDALL_GIT_REF="main"

# Heimdall tunnel auth
export HEIMDALL_TUNNEL_HOST="proxy.example.com"
export HEIMDALL_TUNNEL_PORT="8443"
export HEIMDALL_MACHINE_ID="github-actions-opencode-demo"
export HEIMDALL_TOKEN="replace-with-demo-token"

# Certificates.
# Most deployments can set only the tunnel CA cert and let the script reuse it
# as the MITM CA cert too.
#
# Prefer the *_B64 form when passing multiline PEM through SSH or CI.
export HEIMDALL_TUNNEL_CA_CERT_PEM_B64=""
export HEIMDALL_TUNNEL_CA_CERT_PEM=""

# Optional override when your MITM CA differs from the tunnel CA
export HEIMDALL_MITM_CA_CERT_PEM_B64=""
export HEIMDALL_MITM_CA_CERT_PEM=""

# Transparent interception config
export HEIMDALL_CAPTURE_HOST="true"

# Comma-separated source CIDRs hosted on this same runner machine whose HTTPS
# traffic should also be intercepted. Leave empty unless you run local Docker,
# Podman, or CNI-managed runtimes on this host.
export HEIMDALL_CAPTURE_CIDRS=""

# Comma-separated destination CIDRs that must bypass interception.
export HEIMDALL_EXCLUDE_CIDRS=""

# Optional note shown in the script summary to remind you what to allowlist on
# the proxy server.
export HEIMDALL_RUNNER_SOURCE_CIDR_HINT="203.0.113.10/32"
