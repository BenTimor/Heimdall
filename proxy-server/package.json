{
  "name": "guardian-proxy-server",
  "version": "0.1.0",
  "description": "Secret-injecting HTTPS proxy server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-ca": "tsx scripts/generate-ca.ts",
    "generate-tunnel-cert": "tsx scripts/generate-tunnel-cert.ts",
    "generate-certs": "tsx scripts/generate-ca.ts && tsx scripts/generate-tunnel-cert.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1009.0",
    "node-forge": "^1.3.1",
    "pino": "^9.6.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-forge": "^1.3.11",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
